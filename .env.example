# --- All env vars this app reads (copy to .env; set secrets on the host for deploy) ---
#
# DJANGO_SECRET_KEY     Required for Django; use a long random string. Empty breaks sessions/messages.
# AI_PROVIDER           mock | gemini — controls whether Gemini is used for extraction / combined task LLM.
# AI_API_KEY            Google AI Studio API key when AI_PROVIDER=gemini.
# GEMINI_MODEL          Model id for generativelanguage API (default: gemini-2.0-flash).
# AI_DISABLE_COMBINED_TASK_LLM   Set to 1/true to force separate LLM calls (debug / rate limits).
# AI_DISABLE_LLM_ASSIGNMENT      Set to 1/true to skip LLM team assignment when not using combined JSON.
# AI_DISABLE_LLM_FULFILLMENT     Set to 1/true to skip LLM steps/messages when not using combined JSON.
#
# Not read by Django code but used by the process manager when hosting with gunicorn:
# PORT                  Bind port (Render/Railway set this; gunicorn --bind 0.0.0.0:$PORT).

DJANGO_SECRET_KEY=
AI_PROVIDER=mock
AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# AI_DISABLE_COMBINED_TASK_LLM=1
# AI_DISABLE_LLM_ASSIGNMENT=1
# AI_DISABLE_LLM_FULFILLMENT=1

