# Copy this file to `.env` beside `manage.py` for local overrides.
# Keep that file out of version control. Values are loaded at startup via python-dotenv.
#
# For a public URL, set comma-separated ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS
# (with https://...) in `.env` or in your host’s environment UI — see Django deployment docs.
#
# AI: AI_PROVIDER=mock | gemini | openrouter
# gemini: AI_API_KEY=...  GEMINI_MODEL=gemini-2.0-flash
# openrouter: OPENROUTER_API_KEY=...  (or set AI_API_KEY)  OPENROUTER_MODEL=google/gemini-2.0-flash-001
