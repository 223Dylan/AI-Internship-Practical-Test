AI_PROVIDER=mock
AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Task creation uses ONE Gemini request for intent + assignment + steps/messages when possible.
# Disable to fall back to separate calls (more requests, same end result):
# AI_DISABLE_COMBINED_TASK_LLM=1
